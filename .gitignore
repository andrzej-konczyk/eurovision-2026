# Python environment
.venv/
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/

# Secrets — never commit
.env
.env.*
!.env.example

# ML experiment tracking (tracked by MLflow locally, not Git)
models/mlruns/
mlruns/
mlflow.db

# DVC — raw data and model artefacts tracked by DVC, not Git
data/raw/
data/dvc-cache/
.dvc/tmp/
.dvc/cache/

# Model artefacts — binaries excluded, .dvc pointer files git-tracked
*.pkl
*.pt
*.h5
*.onnx

# Data intermediates — only pointer files go to Git
data/processed/
data/features/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# IDE
.vscode/
.idea/
*.sublime-*

# OS
.DS_Store
Thumbs.db
desktop.ini

# Reports — commit profiling/backtest .md; ignore generated PDFs
reports/*.pdf
reports/*.html
reports/shap_summary_*.png

# Local planning/docs exports
Feasbility Analysis/
PRD/
Project_Execution_documents/

# Node (for Puppeteer/PDF export)
node_modules/

# Local session status — never push to remote
project_status.md
latest_logs/
archived_logs/
